---
import Base from '../layouts/Base.astro';
---

<Base
  title="About_Gentle Tyrant Studio"
  description="Software engineer and indie game developer."
>
  <section class="section">
    <div class="container about-layout">

      <!-- LEFT: bio -->
      <div class="bio fade-up">
        <span class="tag">About</span>
        <h1>Jelle Middendorf</h1>

        <p class="bio-text">
          I'm a software engineer and the person behind Gentle Tyrant Studio.
          I make games because I find the intersection of systems, feel, and
          player psychology genuinely fascinating to work in.
        </p>

        <p class="bio-text">
          This site is built with Astro and Vue, deployed on Cloudflare Pages.
          The source is on
          <a href="https://github.com/yourname" class="inline-link" target="_blank" rel="noopener">
            GitHub
          </a>
          if you're curious.
        </p>

        <div class="bio-links">
          <a href="mailto:gentletyrantstudio@outlook.com" class="btn btn-accent">Email me</a>
          <a href="https://github.com/jellemiddendorf" target="_blank" rel="noopener" class="btn">GitHub ↗</a>
          <a href="https://linkedin.com/in/jelle-middendorf-559a37152" target="_blank" rel="noopener" class="btn">LinkedIn ↗</a>
        </div>
      </div>

      <!-- RIGHT: facts -->
      <aside class="facts fade-up" style="animation-delay: 0.15s">

        <div class="fact-block">
          <h2 class="fact-heading">Education</h2>
          <p class="fact-title">HBO ICT Software Engineer</p>
          <p class="fact-sub">Windesheim · 2019 - 2024</p>
        </div>

        <div class="fact-block">
          <h2 class="fact-heading">Experience</h2>
          <p class="fact-title">AI Engineer</p>
          <p class="fact-sub">Zehnder 2024 – 2025</p>
        </div>

        <div class="fact-block">
          <h2 class="fact-heading">Currently</h2>
          <p class="fact-body">
            Building Project Giza.<br>
            Learning Astro & Vue.<br>
            Playing Factorio.
          </p>
        </div>

        <div class="fact-block">
          <h2 class="fact-heading">Find my games</h2>
          <ul class="fact-list">
            <li>
              <a href="https://gentletyrant.itch.io" target="_blank" rel="noopener" class="inline-link">
                itch.io ↗
              </a>
            </li>
            <li>
              <a href="https://store.steampowered.com/developer/gentletyrant" target="_blank" rel="noopener" class="inline-link">
                Steam ↗
              </a>
            </li>
          </ul>
        </div>

      </aside>
    </div>
  </section>
</Base>

<style>
.about-layout {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: var(--s12);
  align-items: start;
}

/* BIO */
h1 {
  font-family: var(--font-display);
  font-weight: 400;
  margin-top: var(--s2);
  margin-bottom: var(--s4);
  color: var(--ink);
}

.bio-text {
  color: var(--ink-soft);
  margin-bottom: var(--s3);
  max-width: 52ch;
  font-size: 0.875rem;
}

.bio-links {
  display: flex;
  flex-wrap: wrap;
  gap: var(--s2);
  margin-top: var(--s4);
}

.inline-link {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.2s;
}

.inline-link:hover { color: var(--accent-dark); }

/* FACTS */
.facts {
  border-left: 1px solid var(--border);
  padding-left: var(--s6);
  display: flex;
  flex-direction: column;
  gap: var(--s4);
}

.fact-block {
  padding-bottom: var(--s4);
  border-bottom: 1px solid var(--border);
}

.fact-block:last-child { border-bottom: none; }

.fact-heading {
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: var(--s1);
}

.fact-title {
  font-size: 0.9rem;
  color: var(--ink);
}

.fact-sub {
  font-size: 0.8rem;
  color: var(--ink-soft);
  margin-top: 0.2rem;
}

.fact-body {
  font-size: 0.85rem;
  color: var(--ink-soft);
  line-height: 1.7;
}

.fact-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  font-size: 0.85rem;
}

/* MOBILE */
@media (max-width: 700px) {
  .about-layout { grid-template-columns: 1fr; gap: var(--s8); }
  .facts {
    border-left: none;
    padding-left: 0;
    border-top: 1px solid var(--border);
    padding-top: var(--s6);
  }
}
</style>