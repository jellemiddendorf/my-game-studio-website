<style>
/* ─── Hero ───────────────────────────────────── */
.hero {
  position: relative;
  min-height: 90vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hero-inner {
  position: relative;
  z-index: 1;
  padding-block: var(--s12);
}

.hero-eyebrow {
  margin-bottom: var(--s3);
}

.tag {
  display: inline-block;
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid var(--accent-dark);
  background: var(--accent-dim);
  /* color: var(--accent); */
  /* border: 1px solid var(--accent-dim); */
  /* background: rgba(26, 48, 64, 0.4); */
  padding: 0.3em 0.8em;
}

.hero-headline {
  font-family: var(--font-display);
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-weight: 400;
  line-height: 1.05;
  margin-bottom: var(--s4);
  color: var(--ink);
}

.hero-headline em {
  font-style: italic;
  color: var(--accent);
}

.hero-sub {
  font-family: var(--font-display);
  font-style: italic;
  /* font-size: 0.6em; */
  color: var(--ink-muted);
  font-weight: 400;
}
/* .hero-sub {
  font-style: italic;
  color: var(--accent);
} */

.hero-body {
  max-width: 40ch;
  color: var(--ink-muted);
  margin-bottom: var(--s4);
  /* font-size: 0.85rem; */
}

.hero-cta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--s2);
}

/* ─── bg canvas ────────────────────────────── 0.04*/
/* .hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 60% 50% at 65% 50%,
    rgba(168, 212, 232, 0.15) 0%,
    transparent 70%
  );
  pointer-events: none;
} */
/* .bg-canvas {
  position: absolute;
  inset: 0;
  pointer-events: none;
} */

/* ─── Featured section ───────────────────────── */
.section-header {
  margin-bottom: var(--s6);
}

.section-header h2 {
  font-family: var(--font-display);
  font-weight: 400;
  margin-top: var(--s2);
  color: var(--ink);
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--s4);
}

/* ─── Mobile ─────────────────────────────────── */
@media (max-width: 600px) {
  .hero { min-height: 75vh; }
  .cards-grid { grid-template-columns: 1fr; }
}
</style>

