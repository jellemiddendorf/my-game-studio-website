---
import Base from '../layouts/Base.astro';
import ScrambleText from '../components/ScrambleText.vue';
import TypeScramble from '../components/TypeScramble.vue';
import FlipCard from '../components/FlipCard.vue';
import { projects } from '../data/projects';

const featured = projects.filter(p => p.featured);
---

<Base title="Gentle Tyrant Studio_Indie Game Dev">

  <!-- HERO -->
  <section class="hero">

    <!-- Background image -->
    <div class="hero-bg"></div>

    <!-- Borderless glass wash behind text -->
    <div class="hero-wash"></div>

    <div class="container hero-inner fade-up">
      <div class="hero-eyebrow">
        <span class="tag">Indie Game Developer</span>
        <!-- <span class="tag">Software Engineer</span>
        <span class="tag">Indie Game Dev</span> -->
      </div>

      <h1 class="hero-headline">
        <TypeScramble client:load text="GENTLE BY NATURE" delay={0} speed={20}/>
        <br />
        <em class="hero-sub">
          <TypeScramble  client:load text="Tyrannical about game design" delay={0} speed={11.2}/>
        </em>
        <!-- <em class="hero-sub">Tyrannical about game design</em> -->
      </h1>

      <p class="hero-body">
        Solo developer. I program for the same reason people draw,
        because I had ideas that needed somewhere to go.
      </p>

      <div class="hero-cta">
        <a href="/projects" class="btn btn-accent">See my work</a>
        <a href="/about" class="btn">About me</a>
      </div>
    </div>

  </section>

  <!-- FEATURED PROJECTS -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="tag">Projects</span>
        <h2>Featured work</h2>
      </div>

      <div class="cards-grid">
        {featured.map(project => (
          <FlipCard client:visible project={project} />
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
/* ─── Hero ───────────────────────────────────── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}

/* The jungle image covers the full hero */
.hero-bg {
  position: absolute;
  inset: 0;
  background-image: url('/images/jungle3.jpg');
  background-size: cover;
  background-position: center;
  /* Subtle zoom-in on load for a cinematic feel */
  animation: slowZoom 12s ease-out both;
}

@keyframes slowZoom {
  from { transform: scale(1.06); }
  to   { transform: scale(1); }
}

/* Fade the image to black at the bottom
   so the projects section below flows naturally */
.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(10, 10, 10, 0.35) 0%,    /* slight dark tint at top */
    rgba(10, 10, 10, 0.15) 40%,   /* mostly clear in the middle */
    rgba(10, 10, 10, 0.85) 80%,   /* darkening */
    rgba(10, 10, 10, 1)    100%   /* fully black at bottom */
  );
}

/* Borderless wash - dark gradient sitting behind the text only
   no hard edges, fades in all directions */
.hero-wash {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 65%;
  background: linear-gradient(
    to right,
    rgba(10, 10, 10, 0.82) 0%,
    rgba(10, 10, 10, 0.65) 50%,
    rgba(10, 10, 10, 0)    100%
  );
  pointer-events: none;
}

/* Content sits above everything */
.hero-inner {
  position: relative;
  z-index: 2;
  padding-block: var(--s16);
}

/* New */
.hero-inner .btn-accent {
  border-color: var(--accent-dark);
  color: var(--accent);
  background: transparent;
}

.hero-inner .btn-accent:hover {
  background: var(--accent-dim);
  border-color: var(--accent);
  color: var(--accent);
}
/* New */

.hero-eyebrow {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: var(--s3);
}

.hero-headline {
  font-family: var(--font-body);
  font-size: clamp(1.9rem, 5.5vw, 5.5rem);
  font-weight: 400;
  line-height: 1.05;
  margin-bottom: var(--s3);
  color: var(--ink);
}

.hero-sub {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  color: var(--accent);
  display: block;
  font-size: clamp(1.75rem, 5vw, 5rem);
}

.hero-body {
  max-width: 40ch;
  color: var(--ink-soft);
  margin-bottom: var(--s4);
  line-height: 1.75;
}

.hero-cta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--s2);
}

/* ─── Featured section ───────────────────────── */
.section-header {
  margin-bottom: var(--s6);
}

.section-header h2 {
  font-family: var(--font-display);
  font-weight: 400;
  margin-top: var(--s2);
  color: var(--ink);
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--s4);
}

/* ─── Mobile ─────────────────────────────────── */
@media (max-width: 600px) {
  .hero-wash { width: 100%; }
  .cards-grid { grid-template-columns: 1fr; }
}
</style>