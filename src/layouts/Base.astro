---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title = 'Gentle Tyrant Studio',
  description = 'Software developer and indie game dev. I program for the same reason anyone makes anything, because I had ideas that needed somewhere to go. Known online as Lv1Skeleton, studio is Gentle Tyrant.',
  // description = 'Software developer. I program for the same reason anyone makes anything, because I had ideas that needed somewhere to go. Indie games by Jelle Middendorf, Lv1Skeleton, Gentle Tyrant, Gentle Tyrant Studio',
  // description = 'Indie game studio: games, experiments, and dev work.',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->

  <!-- Open Graph Tags For sharing My Website in Socials -->
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://gentletyrantstudio.com/images/og-image.jpg" />
  <meta property="og:site_name" content="Gentle Tyrant Studio" />

  <!-- Twitter/X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://gentletyrantstudio.com/images/og-image.jpg" />
  <!-- Open Graph Tags For sharing My Website in Socials -->

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500&display=swap"
    rel="stylesheet"
  />
</head>

<body>
  <!-- NAV -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="wordmark">
        <div class="logo-placeholder" aria-hidden="true"></div>
        <span class="wordmark-text">Gentle Tyrant Studio</span>
        <span class="wordmark-dot">·</span>
      </a>

      <nav>
        <ul class="nav-links">
          <li>
            <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>
              Home
            </a>
          </li>
          <li>
            <a href="/projects" class:list={['nav-link', { active: currentPath.startsWith('/projects') }]}>
              Projects
            </a>
          </li>
          <li>
            <a href="/about" class:list={['nav-link', { active: currentPath === '/about' }]}>
              About
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- PAGE CONTENT SLOTS-->
  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} Jelle Middendorf - Gentle Tyrant Studio - KVK: 99662582 - BTW-ID: NL005400918B63 - built with Astro &amp; Vue
      </p>
      <ul class="footer-links">
        <li><a href="https://github.com/jellemiddendorf" target="_blank" rel="noopener">GitHub</a></li>
        <li><a href="https://Lv1Skeleton.itch.io" target="_blank" rel="noopener">itch.io</a></li>
        <li><a href="https://ko-fi.com/gentletyrantstudio" target="_blank" rel="noopener">Ko-fi</a></li>
      </ul>
    </div>
  </footer>
<script is:inline src='https://storage.ko-fi.com/cdn/scripts/overlay-widget.js'></script>
<script is:inline>
  kofiWidgetOverlay.draw('gentletyrantstudio', {
    'type': 'floating-chat',
    'floating-chat.donateButton.text': 'Support me',
    'floating-chat.donateButton.background-color': '#ffe177',
    'floating-chat.donateButton.text-color': '#0A0A0A'
  });
</script>
</body>
</html>


<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(10, 10, 10, 0.75); /*0.85*/
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 4rem;
}

.wordmark {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  text-decoration: none;
  min-width: 0;
}

.logo-placeholder {
  width: 32px;
  height: 32px;
  border: 1px solid var(--border);
  background: var(--bg-raised);
  flex-shrink: 0;
  position: relative;
}

.logo-placeholder::before,
.logo-placeholder::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 60%;
  height: 1px;
  background: var(--border);
}

.logo-placeholder::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.logo-placeholder::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.wordmark-text {
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink);

  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.wordmark-dot {
  padding-right: 10px;
  color: var(--accent);
  flex-shrink: 0;
}

/* ─── Nav ────────────────────────────────────── */
.nav-links {
  display: flex;
  list-style: none;
  gap: var(--s4);
  flex-shrink: 0;
}

.nav-link {
  font-size: var(--text-base);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-muted);
  transition: color 0.2s;
  white-space: nowrap;

  position: relative;
  padding-bottom: 2px;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--accent);
  transition: width 0.25s ease;
}

.nav-link:hover,
.nav-link.active {
  color: var(--ink);
}

.nav-link.active::after,
.nav-link:hover::after {
  width: 100%;
}

.site-footer {
  border-top: 1px solid var(--border);
  padding-block: var(--s4);
  margin-top: var(--s12);
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--s2);
}

.footer-copy {
  font-size: 0.8rem;
  color: var(--ink-muted);
}

.footer-links {
  display: flex;
  list-style: none;
  gap: var(--s3);
  font-size: 0.8rem;
  color: var(--ink-muted);
}

.footer-links a:hover {
  color: var(--ink);
}

@media (max-width: 600px) {
  .logo-placeholder { display: none; }
  .wordmark-text {
    font-size: var(--text-sm);
    white-space: normal;
    line-height: 1.3;
  }
  .wordmark-dot { display: none; }
  .nav-links { gap: var(--s2); }
  .nav-link { font-size: var(--text-sm); }
  .footer-inner { flex-direction: column; align-items: flex-start; }
  .site-footer {
    margin-bottom: 3rem;
  }
}
</style>